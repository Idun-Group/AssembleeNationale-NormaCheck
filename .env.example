# NormaCheck — variables d'environnement (toutes optionnelles)
#
# Aucune variable n'est requise en local : l'analyse approfondie utilise
# l'authentification locale de la CLI `claude` (pas de clé API).

# Désactive l'analyse approfondie (couche LLM) et l'indique dans l'UI, avec un
# lien de contact. À "1" pour la démo publique déployée sur Vercel (où la CLI
# `claude` locale n'existe pas). Préfixe NEXT_PUBLIC_ requis : la valeur est
# lue côté client au build.
NEXT_PUBLIC_NORMACHECK_LLM_DISABLED=

# Timeout (ms) d'un appel à la CLI `claude` locale. Par défaut 300000 (5 min) :
# les textes longs demandent 170-240 s. N'a d'effet qu'en local.
NORMACHECK_LLM_TIMEOUT_MS=

# Mode démo hors-ligne : "1" renvoie une réponse LLM simulée sans appeler la CLI.
NORMACHECK_LLM_MOCK=

# Si une bascule vers l'API Anthropic est nécessaire plus tard (réécrire
# uniquement lib/llm/executer.ts) :
# ANTHROPIC_API_KEY=
